# Copy to .env and fill in. .env is gitignored (never commit secrets).

# --- Warehouse -------------------------------------------------------------
# Path to the local DuckDB warehouse file (12-factor: config from the env).
WAREHOUSE_DB=data/warehouse.duckdb

# --- LLM (used later by the governed analytics agent) ----------------------

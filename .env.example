# Copy to .env and fill in. .env is gitignored (never commit secrets).

# --- Warehouse -------------------------------------------------------------
# Path to the local DuckDB warehouse file (12-factor: config from the env).
WAREHOUSE_DB=data/warehouse.duckdb

# --- LLM (used later by the governed analytics agent) ----------------------
# Get a key at https://console.anthropic.com  -> keep it secret.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- REST API (optional) -----------------------------------------------------
# Shared secret required on POST /ask when set (header: X-API-Key).
# Leave empty for local dev; SET it before exposing the API on a network —
# every /ask call triggers billed LLM requests.
# API_TOKEN=

# --- Cost control --------------------------------------------------------------
# Daily question budget per client IP on the billed surfaces (POST /ask and
# the dashboard chat). 0 disables the limit (e.g. local dev with your own key).
RATE_LIMIT_PER_DAY=6
